    amount: parseFloat(document.getElementById('txn-amount').value) || 0,
    company: document.getElementById('txn-company').value,
    category: cat,
    bank: document.getElementById('txn-bank').value,
    mode: document.getElementById('txn-mode').value,
    ref: document.getElementById('txn-ref').value,
    party: document.getElementById('txn-party').value,
    gst: document.getElementById('txn-gst').value,
    gstApplicable: document.getElementById('txn-gst-applicable').value,
    tds: document.getElementById('txn-tds').value,
    tdsAmt: parseFloat(document.getElementById('txn-tds-amt').value) || 0,
    desc: document.getElementById('txn-desc').value,
