let pendingImages = [];
function previewImages(e) {
  const files = Array.from(e.target.files);
  const container = document.getElementById('img-previews');
  files.forEach(f => {
    const reader = new FileReader();
    reader.onload = ev => {
      pendingImages.push(ev.target.result);
