  const incomeByMonth = new Array(12).fill(0);
  const expenseByMonth = new Array(12).fill(0);
  txns.forEach(t => {
    const m = new Date(t.date).getMonth();
    const fyIdx = m >= 3 ? m - 3 : m + 9;
    if (t.type === 'income') incomeByMonth[fyIdx] += t.amount;
    else expenseByMonth[fyIdx] += t.amount;
  });

  if (monthlyChart) monthlyChart.destroy();
  monthlyChart = new Chart(document.getElementById('chart-monthly'), {
    type: 'bar',
    data: {
      labels: months,
      datasets: [
        { label: 'Income', data: incomeByMonth, backgroundColor: '#bbf7d0', borderColor: '#22c55e', borderWidth: 2, borderRadius: 4 },
        { label: 'Expense', data: expenseByMonth, backgroundColor: '#fecaca', borderColor: '#ef4444', borderWidth: 2, borderRadius: 4 }
      ]
    },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'top', labels: { font: { family: 'DM Sans', size: 11 } } } }, scales: { y: { ticks: { callback: v => '₹'+v.toLocaleString('en-IN') } } } }
  });

  // Category
  const catMap = {};
  txns.forEach(t => { catMap[t.category] = (catMap[t.category]||0) + t.amount; });
  const cats = Object.keys(catMap);
  const colors = ['#3b82f6','#22c55e','#f59e0b','#ef4444','#8b5cf6','#06b6d4','#ec4899','#84cc16','#f97316','#14b8a6'];
  if (categoryChart) categoryChart.destroy();
  categoryChart = new Chart(document.getElementById('chart-category'), {
    type: 'doughnut',
    data: { labels: cats, datasets: [{ data: cats.map(c => catMap[c]), backgroundColor: colors, borderWidth: 0 }] },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'right', labels: { font: { family: 'DM Sans', size: 11 }, boxWidth: 10 } } } }
  });

  // Company
  const companyMap = {};
  txns.filter(t => t.type === 'income').forEach(t => { companyMap[t.company] = (companyMap[t.company]||0) + t.amount; });
  if (companyChart) companyChart.destroy();
  companyChart = new Chart(document.getElementById('chart-company'), {
    type: 'bar',
    data: {
      labels: Object.keys(companyMap),
      datasets: [{ label: 'Income', data: Object.values(companyMap), backgroundColor: ['#3b82f6','#22c55e','#f59e0b','#8b5cf6'], borderRadius: 6 }]
    },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { ticks: { callback: v => '₹'+v.toLocaleString('en-IN') } } } }
  });

