function fmt(n) { return '₹' + Math.abs(n).toLocaleString('en-IN', {maximumFractionDigits:0}); }

function renderDashboard() {
  const txns = getFilteredFY();
  const income = txns.filter(t => t.type === 'income');
  const expense = txns.filter(t => t.type === 'expense');
  const totalIncome = income.reduce((a,t) => a + t.amount, 0);
  const totalExpense = expense.reduce((a,t) => a + t.amount, 0);
  const balance = totalIncome - totalExpense;

  document.getElementById('dash-income').textContent = fmt(totalIncome);
  document.getElementById('dash-expense').textContent = fmt(totalExpense);
  document.getElementById('dash-balance').textContent = (balance >= 0 ? '' : '-') + fmt(balance);
  document.getElementById('dash-balance').className = 'stat-value ' + (balance >= 0 ? 'balance' : 'expense');
  document.getElementById('dash-income-count').textContent = income.length + ' entries';
  document.getElementById('dash-expense-count').textContent = expense.length + ' entries';

  // Tax estimate
  const taxable = Math.max(0, balance);
  let tax = calcTaxNew(taxable);
  document.getElementById('dash-tax').textContent = fmt(tax);

  renderCharts(txns);
  renderQuarterlyCards();
}

function calcTaxNew(income) {
  if (income <= 300000) return 0;
  let tax = 0;
  const slabs = [[300000,700000,0.05],[700000,1000000,0.10],[1000000,1200000,0.15],[1200000,1500000,0.20]];
  for (const [low, high, rate] of slabs) {
    if (income > low) tax += Math.min(income, high) * rate - low * rate;
  }
  if (income > 1500000) tax += (income - 1500000) * 0.30;
  return Math.round(tax * 1.04); // with cess
}

function calcTaxOld(income) {
  if (income <= 250000) return 0;
  let tax = 0;
  if (income > 250000) tax += Math.min(income, 500000) * 0.05 - 12500;
  if (income > 500000) tax += Math.min(income, 1000000) * 0.20 - 100000;
  if (income > 1000000) tax += (income - 1000000) * 0.30;
  return Math.round(Math.max(0, tax) * 1.04);
}

function renderCharts(txns) {
  // Monthly chart
