    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'right', labels: { font: { family: 'DM Sans', size: 11 }, boxWidth: 10 } } } }
  });
}

function renderQuarterlyCards() {
  const fys = [...new Set(transactions.map(t => t.fy))].filter(f => f && f !== 'Unknown').sort().reverse();
  if (!fys.length) fys.push(getFY(new Date().toISOString()));
  const container = document.getElementById('quarterly-cards');
  container.innerHTML = '';
  fys.forEach(fy => {
    const quarters = [
      { name: 'Q1', months: [3,4,5], label: 'Apr–Jun' },
      { name: 'Q2', months: [6,7,8], label: 'Jul–Sep' },
      { name: 'Q3', months: [9,10,11], label: 'Oct–Dec' },
      { name: 'Q4', months: [0,1,2], label: 'Jan–Mar' },
    ];
    const div = document.createElement('div');
    div.className = 'fy-card';
    div.innerHTML = `<h4>FY ${fy}</h4>`;
    quarters.forEach(q => {
      const row = document.createElement('div');
      row.className = 'quarter-row';
      const fyTxns = transactions.filter(t => {
        if (t.fy !== fy) return false;
        const m = new Date(t.date).getMonth();
        return q.months.includes(m);
      });
      const inc = fyTxns.filter(t => t.type === 'income').reduce((a,t)=>a+t.amount,0);
      const exp = fyTxns.filter(t => t.type === 'expense').reduce((a,t)=>a+t.amount,0);
      row.innerHTML = `
        <div>
          <div style="font-weight:600;">${q.name} <span style="color:var(--gray-400);font-weight:400;">(${q.label})</span></div>
          <div style="font-size:11px;color:var(--gray-400);">${fyTxns.length} txns · +${fmt(inc)} -${fmt(exp)}</div>
        </div>
        <button class="btn btn-secondary btn-sm" onclick="downloadQuarter('${fy}','${q.name}',${JSON.stringify(q.months)})">⬇ CSV</button>`;
      div.appendChild(row);
    });
    container.appendChild(div);
  });
}

function downloadQuarter(fy, qName, months) {
  const rows = transactions.filter(t => {
    if (t.fy !== fy) return false;
    return months.includes(new Date(t.date).getMonth());
  });
  downloadCSVData(rows, `FinanceOS_${fy}_${qName}`);
}

