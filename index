function renderITR() {
  const txns = transactions;
  const income = txns.filter(t => t.type === 'income');
  const expense = txns.filter(t => t.type === 'expense');

  const totalIncome = income.reduce((a,t) => a+t.amount, 0);
  const totalExpense = expense.reduce((a,t) => a+t.amount, 0);
  const netProfit = totalIncome - totalExpense;

  document.getElementById('itr-gross').textContent = fmt(totalIncome);
  document.getElementById('itr-tax-est').textContent = fmt(calcTaxNew(Math.max(0, netProfit)));

  // Company-wise
  ['Short Stereo','Fillburn','Cleansvy'].forEach((c, i) => {
    const ids = ['itr-ss-income','itr-fb-income','itr-cv-income'];
    const val = income.filter(t => t.company === c).reduce((a,t)=>a+t.amount,0);
    document.getElementById(ids[i]).textContent = fmt(val);
  });
  const other = income.filter(t => t.company === 'Personal').reduce((a,t)=>a+t.amount,0);
  document.getElementById('itr-other-income').textContent = fmt(other);
  document.getElementById('itr-total-income').textContent = fmt(totalIncome);

  // Expense categories
  const catMap = {
    'Marketing & Ads': 'itr-exp-marketing',
    'Software & Subscriptions': 'itr-exp-software',
    'Freelancer Payment': 'itr-exp-freelancer',
    'Employee Salary': 'itr-exp-freelancer',
    'Internet & Telecom': 'itr-exp-internet',
    'Travel & Conveyance': 'itr-exp-travel',
    'Office Rent': 'itr-exp-rent',
  };
  const used = new Set();
  Object.entries(catMap).forEach(([cat, id]) => {
    const v = expense.filter(t => t.category === cat).reduce((a,t)=>a+t.amount,0);
    if (document.getElementById(id)) {
      const cur = parseFloat(document.getElementById(id).textContent.replace(/[^0-9]/g,'')) || 0;
      document.getElementById(id).textContent = fmt(cur + v);
      used.add(cat);
    }
  });
  const otherExp = expense.filter(t => !used.has(t.category)).reduce((a,t)=>a+t.amount,0);
  document.getElementById('itr-exp-other').textContent = fmt(otherExp);
  document.getElementById('itr-total-exp').textContent = fmt(totalExpense);
  document.getElementById('itr-net-profit').textContent = fmt(Math.max(0, netProfit));

  // Tax computation
  const taxNew = calcTaxNew(Math.max(0, netProfit));
  const taxOld = calcTaxOld(Math.max(0, netProfit) - 150000 - 50000); // Standard deduction approx
  document.getElementById('itr-old-tax').textContent = fmt(taxOld);
  document.getElementById('itr-new-tax').textContent = fmt(taxNew);
  document.getElementById('itr-cess').textContent = fmt(Math.round(Math.min(taxNew,taxOld) * 0.04));
  document.getElementById('itr-total-tax').textContent = fmt(taxNew);

  // Bank-wise
  ['Short Stereo Current','Indian Bank Savings','Union Bank Savings'].forEach((b, i) => {
    const ids = ['itr-bank-ss','itr-bank-ib','itr-bank-ub'];
    const inAmt = income.filter(t => t.bank === b).reduce((a,t)=>a+t.amount,0);
    const outAmt = expense.filter(t => t.bank === b).reduce((a,t)=>a+t.amount,0);
    document.getElementById(ids[i]).textContent = `${fmt(inAmt)} in / ${fmt(outAmt)} out`;
  });
}

// ============================================================
// EXPORT
// ============================================================
function exportCSV() {
  downloadCSVData(transactions, 'FinanceOS_All');
}

function downloadCSVData(rows, filename) {
  if (!rows.length) { toast('No data to export.'); return; }
  const headers = ['Date','Type','Category','Company','Amount','Bank','Mode','Party','Reference','GST','TDS Amt','Description','FY'];
  const csvRows = rows.map(t => [
    new Date(t.date).toLocaleDateString('en-IN'),
    t.type, t.category, t.company, t.amount, t.bank, t.mode,
    t.party, t.ref, t.gst, t.tdsAmt, `"${(t.desc||'').replace(/"/g,"'")}"`, t.fy
  ].join(','));
  const blob = new Blob([headers.join(',') + '\n' + csvRows.join('\n')], { type: 'text/csv' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = filename + '.csv';
  a.click();
  toast('Downloaded: ' + filename + '.csv');
}

function exportITRReport() {
  const txns = transactions;
  const income = txns.filter(t=>t.type==='income').reduce((a,t)=>a+t.amount,0);
  const expense = txns.filter(t=>t.type==='expense').reduce((a,t)=>a+t.amount,0);
  const net = income - expense;
  const taxNew = calcTaxNew(Math.max(0,net));
  const lines = [
    'FinanceOS — ITR Summary Report',
    `Generated: ${new Date().toLocaleDateString('en-IN')}`,
    '',
    'INCOME & EXPENSE SUMMARY',
    `Total Income,${fmt(income)}`,
    `Total Expense,${fmt(expense)}`,
    `Net Profit,${fmt(net)}`,
    `Estimated Tax (New Regime),${fmt(taxNew)}`,
    '',
    'ENTITY-WISE INCOME',
    ...['Short Stereo','Fillburn','Cleansvy','Personal'].map(c => {
      const v = txns.filter(t=>t.type==='income'&&t.company===c).reduce((a,t)=>a+t.amount,0);
      return `${c},${fmt(v)}`;
    }),
    '',
    'DOCUMENTS REQUIRED',
    'Invoices issued to clients',
    'Bank statements (all 3 accounts)',
    'Form 26AS and AIS',
    'Vendor invoices for expenses',
    'Form 16A TDS certificates',
    'GST returns (GSTR-1, GSTR-3B)',
    'Advance tax payment challans',
  ];
  const blob = new Blob([lines.join('\n')], { type: 'text/csv' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'ITR_Summary_Report.csv';
  a.click();
  toast('ITR report downloaded!');
}

// ============================================================
// HELPERS
// ============================================================
function closeModal(id) {
  document.getElementById(id).classList.remove('open');
}

function toast(msg) {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.style.display = 'block';
  el.style.opacity = '1';
  setTimeout(() => { el.style.opacity = '0'; setTimeout(() => el.style.display = 'none', 300); }, 2500);
}

// Set current FY
function setCurrentFY() {
  const now = new Date();
  const fy = now.getMonth() >= 3 ? `FY ${now.getFullYear()}-${String(now.getFullYear()+1).slice(-2)}` : `FY ${now.getFullYear()-1}-${String(now.getFullYear()).slice(-2)}`;
  document.getElementById('current-fy').textContent = fy;
}
setCurrentFY();

// Close modal on overlay click
document.querySelectorAll('.modal-overlay').forEach(o => {
  o.addEventListener('click', e => { if (e.target === o) o.classList.remove('open'); });
});

// Init dashboard
renderDashboard();
